# Docker image config
PRODUCT=onlyoffice
REPO=onlyoffice
DOCKER_IMAGE_PREFIX=docspace
DOCKER_TAG=latest
CONTAINER_PREFIX=docspace-
SERVICE_PORT=5050
REGISTRY=
NETWORK_NAME=docspace

# Container user
UID=root
GID=root
EXTRA_HOSTS=

# Node
NODE_OPTIONS=--max_old_space_size=4096

# App config
APP_DOTNET_ENV=
APP_CORE_SERVER_ROOT=
APP_CORE_BASE_DOMAIN=localhost
APP_URL_PORTAL=http://docspace-router:8092
INSTALLATION_TYPE=COMMUNITY
OAUTH_REDIRECT_URL=
WRONG_PORTAL_NAME_URL=
LOG_LEVEL=Warning
DEBUG_INFO=false
ENV_EXTENSION=none

# Security
APP_CORE_MACHINEKEY=LWn4umwBkJl20wdnVx8BFSUhsMkA8nMOIkE2ndtZ
APP_KNOWN_PROXIES=0.0.0.0/0
APP_KNOWN_NETWORKS=0.0.0.0/0

# SSL (handled by Traefik)
CERTIFICATE_PATH=
CERTIFICATE_KEY_PATH=
DHPARAM_PATH=

# External port (Traefik handles this)
EXTERNAL_PORT=80

# Document Server
DOCUMENT_CONTAINER_NAME=docspace-document-server
DOCUMENT_SERVER_URL_EXTERNAL=
DOCUMENT_SERVER_JWT_SECRET=SKSWdY2ZrtAMLP7zmjmlBaG6Jzk4gwtmPqPmVwwH
DOCUMENT_SERVER_JWT_HEADER=AuthorizationJwt
DOCUMENT_SERVER_URL_PUBLIC=/ds-vpath/
DOCUMENT_SERVER_VERSION=latest
DOCUMENT_SERVER_IMAGE_NAME=onlyoffice/documentserver:latest

# MySQL
MYSQL_VERSION=8.3.0
MYSQL_IMAGE=mysql:8.3.0
MYSQL_CONTAINER_NAME=docspace-mysql-server
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=8x2oPXm8KtnKH1He7UUQFogU
MYSQL_DATABASE=docspace
MYSQL_USER=onlyoffice_user
MYSQL_PASSWORD=rYQtWAhJavWk3Ju2IGudpq1J
DATABASE_MIGRATION=false
MIGRATION_TYPE=SAAS

# Redis
REDIS_VERSION=7
REDIS_IMAGE_NAME=redis:7
REDIS_CONTAINER_NAME=docspace-redis
REDIS_HOST=
